{
  "name": "chat-app-monorepo",
  "version": "1.0.0",
  "description": "Full-stack real-time chat application",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "install:all": "npm install && cd frontend && npm install",
    "build": "cd frontend && npx vite build",
    "lint": "cd frontend && npm run lint"
  },
  "keywords": [
    "chat",
    "socket.io",
    "react",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.14"
  }
}
